<%= render Blacklight::System::ModalComponent.new do |component| %>
  <% component.with_header do %>
    <h2 class="modal-title">Cite</h2><div class="badge rounded-pill" data-role="bookmark-counter"><%= @documents.count %> records</div>
  <% end %>

    <%= render Citations::MultipleCitationsComponent.new(documents: @documents, oclc_citations: @oclc_citations) %>

  <% component.with_footer do %>
    <button type="button" class="btn btn-outline-primary" data-bl-dismiss="modal">Close</button>
  <% end %>
<% end %>
