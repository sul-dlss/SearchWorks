<% content_for(:head) do %>
  <meta name="blacklight-search-storage" content="<%= blacklight_config.track_search_session.storage %>">
<% end %>

<% if has_search_parameters? %>
  <% masthead = capture { render_masthead_partial } %>
  <% content_for(:search_navbar) { masthead } if html_present?(masthead) %>

  <%= render partial: "search_results" %>
<% else %>
  <%= render partial: "home_page" %>
<% end %>
