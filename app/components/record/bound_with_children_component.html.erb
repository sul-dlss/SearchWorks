<div class="bound-with-type">Bound with:</div>
<ul class="list-unstyled mb-0">
  <% bound_with_children.each do |child| %>
      <% child.items.each do |item| %>
        <li class="pb-2">
          <div class="bound-with-title"><%= (instance_id == child.id ? tag.em('Same title') : link_to(child['title_full_display'], solr_document_path(child.id), data: { turbo: false })) %></div>
          <div class="bound-with-callnumber"><%= item.callnumber %></div>
        </li>
      <% end %>
  <% end %>
</ul>
