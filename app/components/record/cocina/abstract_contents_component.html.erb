<%= render Searchworks4::DocumentSectionLayout.new(title: 'Abstract/Contents', dl_classes: 'dl-horizontal dl-text') do %>
  <% fields.each do |field| %>
    <%= tag.div class: 'my-2' do %>
      <%= tag.dt field.label %>
      <%= tag.dd data: { controller: 'long-text', 'long-text-truncate-class': 'truncate-5' } do %>
        <%= tag.div data: { 'long-text-target': 'text' } do %>
          <% field.values.each do |value| %>
            <%= tag.p value %>
          <% end %>
        <% end %>
      <% end %>
    <% end %>
  <% end %>
<% end %>
