<%= render Searchworks4::DocumentSectionLayout.new(title: 'Creators/Contributors') do %>
  <% contributor_display_data.each do |field| %>
    <%= tag.div class: 'my-2', data: { controller: 'list-toggle', 'list-toggle-target': 'group' } do %>
      <%= tag.dt field.label %>
      <% field.objects.each do |contributor| %>
        <% contributor.display_names(with_date: true).each do |name| %>
          <%= tag.dd do %>
            <%= link_to(name, search_catalog_path(q: "\"#{name}\"", search_field: 'search_author')) %>
          <% end %>
        <% end %>
      <% end %>
    <% end %>
  <% end %>
<% end %>
