[
  {
    "description": "Initialize the MCP connection",
    "request": {
      "jsonrpc": "2.0",
      "id": "1",
      "method": "initialize",
      "params": {
        "protocolVersion": "2024-10-07",
        "capabilities": {},
        "clientInfo": {
          "name": "test-client",
          "version": "1.0.0"
        }
      }
    }
  },
  {
    "description": "List available tools",
    "request": {
      "jsonrpc": "2.0",
      "id": "2",
      "method": "tools/list"
    }
  },
  {
    "description": "Ping the server",
    "request": {
      "jsonrpc": "2.0",
      "id": "3",
      "method": "ping"
    }
  },
  {
    "description": "Search catalog for books about physics",
    "request": {
      "jsonrpc": "2.0",
      "id": "4",
      "method": "tools/call",
      "params": {
        "name": "catalog_search_tool",
        "arguments": {
          "query": "physics",
          "rows": 5
        }
      }
    }
  },
  {
    "description": "Search catalog by title",
    "request": {
      "jsonrpc": "2.0",
      "id": "5",
      "method": "tools/call",
      "params": {
        "name": "catalog_search_tool",
        "arguments": {
          "query": "Pride and Prejudice",
          "search_field": "title",
          "rows": 3
        }
      }
    }
  },
  {
    "description": "Search catalog by author (shows available facet refinements)",
