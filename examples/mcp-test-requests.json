      "jsonrpc": "2.0",
      "id": "6",
      "method": "tools/call",
      "params": {
        "name": "catalog_search_tool",
        "arguments": {
          "query": "physics",
          "search_field": "all_fields",
          "rows": 5
        }
      }
    }
  },
  {
    "description": "Search catalog with specific query (demonstrates facet suggestions)",
